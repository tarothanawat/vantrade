# Copy this file to .env and fill in the values

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/vantrade"

# AES-256-GCM encryption key for Alpaca API key storage
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="<32-byte-hex-string>"

# JWT signing secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="<random-256-bit-string>"

# Alpaca Paper Trading credentials — system-level, used for health checks
ALPACA_API_KEY="<your-alpaca-api-key>"
ALPACA_API_SECRET="<your-alpaca-api-secret>"

# Allowed origin for CORS (Next.js web app)
WEB_URL="http://localhost:3000"

# NestJS server port
PORT=4000

# Market hours timezone (IANA timezone name). Defaults to America/New_York (US Eastern).
# Override for non-US deployments, e.g. Europe/London for LSE instruments.
# MARKET_TIMEZONE=America/New_York
