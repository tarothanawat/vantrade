{
  "name": "@vantrade/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@vantrade/types": "workspace:*",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.5",
    "tailwindcss": "^3.4.4",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.4"
  },
  "jest": {
    "rootDir": ".",
    "testEnvironment": "jsdom",
    "testRegex": ".*\\.spec\\.tsx?$",
    "transform": {
      "^.+\\.(t|j)sx?$": ["ts-jest", {
        "tsconfig": {
          "jsx": "react-jsx",
          "moduleResolution": "node"
        }
      }]
    },
    "moduleNameMapper": {
      "^@vantrade/types$": "<rootDir>/../../packages/types/src/index.ts",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFilesAfterEnv": ["@testing-library/jest-dom"]
  }
}
